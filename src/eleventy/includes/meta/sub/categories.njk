<h2>Browse by category</h2>
<ul class=" [ cluster ] " style="line-height: var(--line-height-code);">
	{% for lookup in collections.categories -%}
		<li class=" [ no-wrap ] ">
			{% if page.url != '/' + lookup.plural + '/' -%}
				<a href="/{{ lookup.plural }}/" {% if category == lookup.title %}class=" [ button  button--text ] "{% endif %}>
			{%- else -%}
				<strong>
			{%- endif %}
				<c-icon style="padding-inline-end: .625ch;"><i class="fas fa-{{ lookup.icon | default('file') }}"></i></c-icon>{{ lookup.properPlural | title }}
			{% if page.url != '/' + lookup.plural + '/' -%}
				</a>
			{%- else -%}
				</strong>
			{%- endif %}
		</li>
	{%- endfor %}
</ul>
