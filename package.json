  "funding": [
    {
      "type": "buymeacoffee",
      "url": "https://buymeacoffee.com/chrisburnell"
    }
  ],
  "private": true,
  "main": "index.html",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm exec eleventy --incremental",
    "build:dev": "pnpm run setup && cross-env DEV_MODE=true GENERATE_OG_IMAGES=true pnpm exec eleventy --incremental",
    "build:prod": "pnpm run setup && cross-env GENERATE_OG_IMAGES=true pnpm exec eleventy --incremental",
    "css": "postcss \"src/css/*.css\" --dir \"_site/css\" --no-map",
    "check": "node cli/index.js check",
    "check:css": "node cli/index.js calculateCSSComplexity",
    "check:datetimes": "node cli/index.js checkDates",
    "check:links": "node cli/index.js checkLinks",
    "check:stats": "node cli/index.js checkStats",
    "checks": "pnpm run check",
    "clean": "pnpm exec rimraf .cache && pnpm exec rimraf _site",
    "cli": "node cli/index.js wizard",
    "create-search-index": "pnpm exec pagefind --site \"_site\" --glob \"**/*.html\"",
    "debug": "cross-env DEBUG=Eleventy:Benchmark* pnpm exec eleventy",
    "lint": "pnpm exec eslint \"src/**/*.js\"",
    "now": "pnpm exec eleventy --ignore-initial --incremental --serve",
    "pregenerate": "pnpm run setup && cross-env PREGENERATE_IMAGES=true pnpm exec eleventy",
    "prettier": "pnpm exec prettier --write --list-different src",
    "setup": "pnx update-browserslist-db@latest && pnpm run css && pnpm run prettier",
    "start": "pnpm run css && pnpm exec eleventy --incremental --serve",
    "test": "pnpm exec vitest run",
    "wizard": "pnpm run cli"
  },
  "keywords": [],
  "dependencies": {
